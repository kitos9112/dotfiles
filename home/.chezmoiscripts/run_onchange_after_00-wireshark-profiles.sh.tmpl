{{- if or (eq .chezmoi.os "linux") (eq .chezmoi.os "darwin") -}}
{{- $src_folder := joinPath .chezmoi.homeDir ".config" "wireshark_profiles" -}}
#! /usr/bin/env bash

set -euo pipefail

# Re-run whenever the upstream wireshark_profiles checkout changes: embedding the
# external's git HEAD makes this script's contents change, which is what triggers
# chezmoi's run_onchange re-execution.
{{ if stat (joinPath $src_folder ".git" "HEAD") -}}
{{- $git_head := regexReplaceAll "^ref: *" (include (joinPath $src_folder ".git" "HEAD")) "" -}}
{{- $git_head := regexReplaceAll "\\s*$" $git_head "" -}}
# wireshark_profiles git HEAD: {{ $git_head }}
{{- if stat (joinPath $src_folder ".git" $git_head) }}
# resolves to: {{ include (joinPath $src_folder ".git" $git_head) | trim }}
{{- end }}
{{- end }}

src_dir="${HOME}/.config/wireshark_profiles"
dest_dir="${HOME}/.config/wireshark/profiles"

# Nothing to install if the external was never fetched (e.g. DOTFILES_TEST=true).
if [[ ! -d "${src_dir}" ]]; then
  exit 0
fi

mkdir -p "${dest_dir}"

shopt -s nullglob
zips=("${src_dir}"/*.zip)
shopt -u nullglob

if [[ "${#zips[@]}" -eq 0 ]]; then
  printf "\033[1;33m--> No wireshark profile archives found in %s\033[0m\n" "${src_dir}"
  exit 0
fi

for zip_file in "${zips[@]}"; do
  printf "\033[0;34m--> Installing wireshark profile %s\033[0m\n" "$(basename "${zip_file}" .zip)"
  unzip -q -o -d "${dest_dir}" "${zip_file}"
done
{{- end -}}
