{{- $personalName := .personal_name -}}
{{- if not $personalName -}}
{{- $personalName = .name -}}
{{- end -}}
{{- $personalEmail := .personal_email -}}
{{- if not $personalEmail -}}
{{- $personalEmail = .email -}}
{{- end -}}
{{- $workName := .work_name -}}
{{- if not $workName -}}
{{- $workName = .name -}}
{{- end -}}
{{- $defaultName := $personalName -}}
{{- $defaultEmail := $personalEmail -}}
{{- if and .is_work .work_email -}}
{{- $defaultName = $workName -}}
{{- $defaultEmail = .work_email -}}
{{- end -}}
[init]
  defaultBranch = main

[user]
  name = {{ $defaultName }}
  email = {{ $defaultEmail }}
  {{ if .signing_key -}}
  signingKey = {{ .signing_key }}
  {{- end }}

[credential]
  helper = store

[alias]
  plog = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
  vfc = verify-commit
  st = status
  squash-all = "!f(){ git reset $(git commit-tree HEAD^{tree} -m \"${1:-A new start}\");};f"

[diff]
  ignoreSubmodules = dirty
  guitool = personal

[difftool "personal"]
  cmd = {{ .editor }}

[push]
  default=simple
  followTags=false
  autoSetupRemote=true

[pull]
  rebase = true

[commit]
  {{ if .signing_key -}}
  gpgsign = true
  {{ else -}}
  gpgsign = false
  {{ end -}}

{{- if and (.signing_key) (eq .signing_format "ssh") }}
[gpg]
  format = "ssh"

[gpg "ssh"]
  program = {{ .signing_ssh_program }}
{{- end }}

{{- if and .work_email .work_gitdir }}

[includeIf "gitdir:{{ .work_gitdir }}"]
  path = ~/.gitconfig-work
{{- end }}
