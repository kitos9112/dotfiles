#!/usr/bin/env bash

set -euo pipefail

DEFAULT_OP_ITEM={{ .shell_history_backup_document | toJson }}
DEFAULT_OP_VAULT={{ .shell_history_backup_vault | toJson }}
DEFAULT_ARCHIVE_NAME={{ (or .shell_history_backup_archive_name "shell-history.zip") | toJson }}
ENV_FILE="${HOME}/.config/backup-shell-history-to-1password.env"

VERBOSE=0
DRY_RUN=0
TMP_WORKDIR=""

print_config_menu() {
  local reason=$1
  cat >&2 <<EOF
Configuration help
  Reason: ${reason}
  Config file: ${ENV_FILE}

Required values:
  OP_SERVICE_ACCOUNT_TOKEN  Service account token, e.g. ops_...
  OP_VAULT                  Vault ID or name
  OP_ITEM_ID or OP_ITEM     Document ID or title

Optional value:
  ARCHIVE_NAME              Defaults to ${DEFAULT_ARCHIVE_NAME}

Expected file content:
  OP_SERVICE_ACCOUNT_TOKEN='ops_...'
  OP_VAULT='vault-id'
  OP_ITEM_ID='document-id'
  ARCHIVE_NAME='${DEFAULT_ARCHIVE_NAME}'

After updating the file:
  1. Run this script again manually.
  2. If you use cron or anacron, install or update that scheduler entry separately.
EOF
}

write_env_file_template() {
  local config_dir
  local template_vault
  local template_item

  config_dir="$(dirname "${ENV_FILE}")"
  template_vault="${DEFAULT_OP_VAULT}"
  template_item="${DEFAULT_OP_ITEM}"

  umask 077
  mkdir -p "${config_dir}"

  if [ ! -e "${ENV_FILE}" ]; then
    cat >"${ENV_FILE}" <<EOF
# Populate this file with the 1Password service account settings used by
# backup-shell-history-to-1password.sh.

OP_SERVICE_ACCOUNT_TOKEN=''
OP_VAULT='${template_vault}'
OP_ITEM_ID=''
# OP_ITEM='${template_item}'
ARCHIVE_NAME='${DEFAULT_ARCHIVE_NAME}'
EOF
  fi

  chmod 600 "${ENV_FILE}" 2>/dev/null || true
}

usage() {
  cat <<EOF
Usage: backup-shell-history-to-1password.sh [--dry-run] [--verbose] [--help]

Back up ~/.bash_history and ~/.zsh_history, if present, into a single ZIP archive
and upload that ZIP to an existing 1Password Document item.

Options:
  --dry-run  Create the ZIP locally but do not authenticate or upload it.
  --verbose  Print additional progress messages.
  --help     Show this help text.

Environment:
  The script expects a readable env file at:
    ${ENV_FILE}

  Required variables in that env file:
    OP_SERVICE_ACCOUNT_TOKEN
    OP_VAULT
    OP_ITEM_ID or OP_ITEM

  Optional variables:
    ARCHIVE_NAME
    OP_ITEM
    OP_ITEM_ID

Default chezmoi data:
  shell_history_backup_document: {{ if .shell_history_backup_document }}{{ .shell_history_backup_document }}{{ else }}<unset>{{ end }}
  shell_history_backup_vault: {{ if .shell_history_backup_vault }}{{ .shell_history_backup_vault }}{{ else }}<unset>{{ end }}
  shell_history_backup_archive_name: {{ if .shell_history_backup_archive_name }}{{ .shell_history_backup_archive_name }}{{ else }}shell-history.zip{{ end }}
EOF
}

log() {
  printf '%s\n' "$*"
}

log_verbose() {
  if [ "$VERBOSE" -eq 1 ]; then
    log "$@"
  fi
}

log_error() {
  printf 'Error: %s\n' "$*" >&2
}

die() {
  local exit_code=$1
  shift
  log_error "$@"
  exit "$exit_code"
}

cleanup() {
  if [ -n "$TMP_WORKDIR" ] && [ -d "$TMP_WORKDIR" ]; then
    rm -rf "$TMP_WORKDIR"
  fi
}

trap cleanup EXIT HUP INT TERM

while [ "$#" -gt 0 ]; do
  case "$1" in
    --help)
      usage
      exit 0
      ;;
    --dry-run)
      DRY_RUN=1
      ;;
    --verbose)
      VERBOSE=1
      ;;
    *)
      die 2 "unknown option: $1"
      ;;
  esac
  shift
done

if [ ! -e "${ENV_FILE}" ]; then
  write_env_file_template
  print_config_menu "Created a new template config file."
  die 2 "created template config file: ${ENV_FILE}"
fi

if [ ! -r "${ENV_FILE}" ]; then
  print_config_menu "The config file exists but is not readable."
  die 2 "required env file is missing or unreadable: ${ENV_FILE}"
fi

set +e
set -a
. "${ENV_FILE}"
source_status=$?
set +a
set -e

if [ "${source_status}" -ne 0 ]; then
  print_config_menu "The config file could not be parsed by Bash."
  die 2 "failed to parse config file: ${ENV_FILE}"
fi

chmod 600 "${ENV_FILE}" 2>/dev/null || true

unset OP_CONNECT_HOST OP_CONNECT_TOKEN

for dependency in op zip; do
  if ! command -v "$dependency" >/dev/null 2>&1; then
    die 127 "missing dependency: $dependency"
  fi
done

item_ref="${OP_ITEM_ID:-}"
if [ -z "$item_ref" ]; then
  item_ref="${OP_ITEM:-$DEFAULT_OP_ITEM}"
fi

op_vault="${OP_VAULT:-$DEFAULT_OP_VAULT}"
archive_name="${ARCHIVE_NAME:-$DEFAULT_ARCHIVE_NAME}"
if [ -z "$archive_name" ]; then
  archive_name="shell-history.zip"
fi

missing_config=()

if [ -z "${OP_SERVICE_ACCOUNT_TOKEN:-}" ]; then
  missing_config+=("OP_SERVICE_ACCOUNT_TOKEN")
fi

if [ -z "${op_vault}" ]; then
  missing_config+=("OP_VAULT")
fi

if [ -z "${item_ref}" ]; then
  missing_config+=("OP_ITEM_ID or OP_ITEM")
fi

if [ "${#missing_config[@]}" -gt 0 ]; then
  print_config_menu "Missing required values: ${missing_config[*]}"
  die 2 "config file is missing required values: ${missing_config[*]}"
fi

history_entries=()

if [ -f "${HOME}/.bash_history" ]; then
  history_entries+=(".bash_history")
fi

if [ -f "${HOME}/.zsh_history" ]; then
  history_entries+=(".zsh_history")
fi

if [ "${#history_entries[@]}" -eq 0 ]; then
  die 1 "no shell history files found. Expected ${HOME}/.bash_history and/or ${HOME}/.zsh_history."
fi

umask 077
TMP_WORKDIR="$(mktemp -d "${TMPDIR:-/tmp}/backup-shell-history-to-1password.XXXXXX")"
stage_dir="${TMP_WORKDIR}/staging"
archive_path="${TMP_WORKDIR}/${archive_name}"

mkdir -p "${stage_dir}"

log "Preparing ${archive_name} from shell history files."
log_verbose "Using temporary directory: ${TMP_WORKDIR}"

for entry in "${history_entries[@]}"; do
  cp "${HOME}/${entry}" "${stage_dir}/${entry}"
  log_verbose "Included ${HOME}/${entry}"
done

zip_cmd=(zip -X)
if [ "$VERBOSE" -eq 0 ]; then
  zip_cmd+=(-q)
fi
zip_cmd+=("${archive_path}")
zip_cmd+=("${history_entries[@]}")

(
  cd "${stage_dir}"
  "${zip_cmd[@]}"
)

rm -f "${stage_dir}/.bash_history" "${stage_dir}/.zsh_history"
rmdir "${stage_dir}" 2>/dev/null || true

log "Created archive ${archive_name} with ${#history_entries[@]} file(s)."

if [ "$DRY_RUN" -eq 1 ]; then
  log "Dry run: would upload ${archive_name} to 1Password document '${item_ref}'."
  log_verbose "Dry run would scope lookup to vault '${op_vault}'."
  exit 0
fi

if ! op whoami >/dev/null 2>&1; then
  die 1 "1Password CLI authentication failed. Check OP_SERVICE_ACCOUNT_TOKEN in ${ENV_FILE}."
fi

op_cmd=(op document edit "${item_ref}" "${archive_path}" --file-name "${archive_name}")
if [ -n "$op_vault" ]; then
  op_cmd+=(--vault "${op_vault}")
fi

log "Uploading ${archive_name} to 1Password document '${item_ref}'."
if ! "${op_cmd[@]}"; then
  die 1 "failed to upload ${archive_name} to 1Password."
fi

log "Upload completed."
